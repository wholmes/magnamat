# --- PostgreSQL ---
# Local: default port 5432, or 5434 with `docker compose up -d` (see `.env.docker.example`).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/magnamat?schema=public"

# Neon (example — pooled URL is fine for `next dev` / Vercel runtime):
# DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
#
# If `prisma migrate deploy` fails on Neon (pooler), temporarily point DATABASE_URL at the **direct**
# (non-`-pooler`) connection string from the Neon dashboard, run migrate, then restore the pooled URL.

# Optional: absolute origin for server-side UTM helpers (`lib/utm.ts`).
# NEXT_PUBLIC_SITE_URL="https://www.example.com"

# --- CMS (/admin after sign-in at /admin/login) ---
CMS_ADMIN_PASSWORD="change-me-to-a-long-random-secret"
# Generate: openssl rand -base64 32
CMS_SESSION_SECRET="minimum-24-characters-required-here"
