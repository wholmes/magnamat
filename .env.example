# --- PostgreSQL ---
#
# Local development (recommended): use the Postgres from this repo’s docker-compose.
#   npm run db:up
#   npm run db:migrate:deploy
#   npm run db:seed
# Then `npm run dev` — `DATABASE_URL` must use the **same host port** as Docker (default 5434).
# If `Bind for 0.0.0.0:5434 failed: port is already allocated`, set both lines below to another port, e.g. 55434.
#
# POSTGRES_HOST_PORT is read by docker-compose.yml for the published port.
POSTGRES_HOST_PORT=5434
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5434/magnamat?schema=public"
#
# Alternative local: Homebrew Postgres on 5432 — create DB `magnamat` and use:
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/magnamat?schema=public"
#
# --- Production / preview (Vercel, CI) only ---
# Set DATABASE_URL in the host dashboard — Neon or any Postgres. Example Neon (pooled):
# postgresql://USER:PASS@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&connect_timeout=15
# If `prisma migrate deploy` fails on Neon’s pooler, use Neon’s **direct** (non-pooler) URL for that
# command only, then restore the pooled URL for the app.

# Optional: absolute origin for server-side UTM helpers (`lib/utm.ts`).
# NEXT_PUBLIC_SITE_URL="https://www.example.com"

# Optional: POST contact form JSON to a webhook (Slack incoming URL, Zapier, Make, etc.).
# Without it, `/contact` submissions are logged server-side only (fine for local/staging).
# CONTACT_WEBHOOK_URL="https://hooks.slack.com/services/…"

# --- CMS (/admin after sign-in at /admin/login) ---
CMS_ADMIN_PASSWORD="change-me-to-a-long-random-secret"
# Generate: openssl rand -base64 32
CMS_SESSION_SECRET="minimum-24-characters-required-here"
